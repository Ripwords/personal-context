# === Postgres (compose composes DATABASE_URL from these) ===
POSTGRES_USER=braindump
POSTGRES_PASSWORD=change-me
POSTGRES_DB=braindump
POSTGRES_PORT=5432

# === Production Docker Compose ===
# Optional, but useful when self-hosting with docker-compose.prod.yml.
# Keep Postgres/Ollama bound to 127.0.0.1 unless you explicitly need host/LAN
# access. If you put the app behind a reverse proxy, set APP_BIND=127.0.0.1 too.
COMPOSE_PROJECT_NAME=braindump
APP_BIND=0.0.0.0
APP_PORT=3000
POSTGRES_BIND=127.0.0.1
OLLAMA_BIND=127.0.0.1
OLLAMA_PORT=11434
IMAGE_REGISTRY=braindump
IMAGE_TAG=latest

# Local (non-Docker) dev/test point at the local container; compose overrides
# DATABASE_URL internally to the `postgres` service host.
DATABASE_URL=postgresql://braindump:change-me@localhost:5432/braindump
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/braindump_test

# === Better Auth ===
BETTER_AUTH_SECRET=run-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# === Google OAuth (Calendar) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === AI provider (configurable; deepseek default) ===
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# === Web search (optional; powers the chat `web_search` tool) ===
# Set ONE of these to enable live web results. Left empty, web search returns no results.
TAVILY_API_KEY=
BRAVE_API_KEY=
SEARXNG_URL=

# === Semantic memory + RAG (optional; pgvector + Ollama embeddings) ===
# Turn on to embed memories/document chunks and use hybrid (vector + FTS) recall.
# Requires the pgvector Postgres image and running drizzle/optional/pgvector.sql.
# Left off, recall uses Postgres full-text search.
EMBEDDINGS_ENABLED=0
# Local Bun dev default. docker-compose.prod.yml uses APP_OLLAMA_URL below for
# the app container, because localhost inside the container is not the host.
OLLAMA_URL=http://localhost:11434
APP_OLLAMA_URL=http://ollama:11434
EMBEDDINGS_MODEL=nomic-embed-text

# === Object storage (optional; document originals) ===
# Set all four to store uploads in S3-compatible object storage (garage/MinIO/AWS)
# instead of the local ./uploads dir. Endpoint is required for non-AWS stores.
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
